# Copy this file to `.env` and adjust the values for your environment.
# `.env` is gitignored because JWT_SECRET is a secret.

DATABASE_URL=postgres://finance:finance@localhost:5432/financedb?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-secret
JWT_VALIDITY_DAYS=30
BF_ROUNDS=10
BIND_ADDR=127.0.0.1
PORT=8000
# DB_POOL_SIZE=20
RUST_LOG=finance=debug,tower_http=debug,info
